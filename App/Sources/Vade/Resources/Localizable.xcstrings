    "Arkadaşına verdiğin, komşundan aldığın, unutulan ya da unutulması istenmeyen her borç burada güvenle kayıt altında.": {
      "comment": "Onboarding page 1 subtitle",
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": ""
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every debt you lend to a friend or borrow from a neighbor — whether forgotten or meant to be remembered — is safely recorded here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": ""
          }
        },
        "hi": {
          "stringUnit": {
            "state": "needs_review",
            "value": ""
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkadaşına verdiğin, komşundan aldığın, unutulan ya da unutulması istenmeyen her borç burada güvenle kayıt altında."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "needs_review",
            "value": ""
          }
        }
      }
    },

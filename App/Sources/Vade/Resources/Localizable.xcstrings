    "onboarding.welcome.title": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vade"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vade"
          }
        }
      }
    },
    "onboarding.welcome.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Borç-alacak takibin için şık ve güvenli çözüm. Kimseye unutulan bir hesap kalmayacak."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Elegant and secure debt tracking. Never lose track of who owes what."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seguimiento de deudas elegante y seguro. Nunca pierdas de vista quién debe qué."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "优雅安全的债务追踪。不再忘记谁欠了什么。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुरुचिपूर्ण और सुरक्षित ऋण ट्रैकिंग। कौन क्या बकाया है, कभी न भूलें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتبع ديون أنيق وآمن. لا تفقد أبدًا مسار من يدين بماذا."
          }
        }
      }
    },
    "onboarding.features.title": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her şey elinin altında"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything at your fingertips"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo al alcance de tu mano"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一切尽在掌握"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब कुछ आपकी उंगलियों पर"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كل شيء في متناول يدك"
          }
        }
      }
    },
    "onboarding.feature.track": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alacak & Borç Takibi"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track Receivables & Payables"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seguimiento de cuentas por cobrar y pagar"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应收应付追踪"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्राप्य और देय ट्रैकिंग"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتبع المستحقات والمدفوعات"
          }
        }
      }
    },
    "onboarding.feature.track.desc": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kimden alacaklı, kime borçlusun — tek ekranda net gör."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See who owes you and who you owe — all on one screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve quién te debe y a quién le debes, todo en una pantalla."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一目了然谁欠你、你欠谁。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "देखें कौन आपका बकायादार है और आप किसके — एक स्क्रीन पर।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعرف من يدين لك ومن تدين له — كل ذلك في شاشة واحدة."
          }
        }
      }
    },
    "onboarding.feature.insights": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grafikler & İstatistikler"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Charts & Statistics"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gráficos y estadísticas"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "图表与统计"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चार्ट और सांख्यिकी"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رسوم بيانية وإحصائيات"
          }
        }
      }
    },
    "onboarding.feature.insights.desc": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aylık trendler, döviz dağılımı, kişi bazlı analizler."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Monthly trends, currency breakdowns, per-person analytics."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tendencias mensuales, desglose por moneda, análisis por persona."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "月度趋势、货币分布、个人分析。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मासिक रुझान, मुद्रा विवरण, प्रति-व्यक्ति विश्लेषण।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتجاهات شهرية، توزيع العملات، تحليلات لكل شخص."
          }
        }
      }
    },
    "onboarding.feature.reminders": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vade Bildirimleri"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Due Date Reminders"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recordatorios de vencimiento"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "到期提醒"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नियत तिथि अनुस्मारक"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تذكيرات تاريخ الاستحقاق"
          }
        }
      }
    },
    "onboarding.feature.reminders.desc": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ödeme günü yaklaşınca sana haber verir, hiçbir şeyi kaçırmazsın."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get notified when payments are due — never miss a thing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibe notificaciones cuando los pagos estén por vencer."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "付款到期时收到通知，不会错过任何事。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "भुगतान की नियत तिथि पर सूचना पाएं — कभी कुछ न चूकें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احصل على إشعارات عند استحقاق المدفوعات — لا تفوّت شيئًا."
          }
        }
      }
    },
    "onboarding.privacy.title": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verilerin sana ait"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your data stays yours"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus datos son tuyos"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的数据归你所有"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका डेटा आपका ही रहता है"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بياناتك تبقى لك"
          }
        }
      }
    },
    "onboarding.privacy.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiçbir sunucuya gönderilmez. Reklam ve analitik servisleri yalnızca anonim veri kullanır. Dilediğin an Ayarlar'dan kapatabilirsin."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing is sent to servers. Ads and analytics use only anonymous data. You can disable them anytime in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se envía nada a servidores. Los anuncios y análisis solo usan datos anónimos. Puedes desactivarlos en Ajustes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不会发送任何数据到服务器。广告和分析仅使用匿名数据。您可以随时在设置中关闭。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई भी डेटा सर्वर पर नहीं भेजा जाता। विज्ञापन और विश्लेषण केवल गुमनाम डेटा का उपयोग करते हैं। आप सेटिंग्स में कभी भी बंद कर सकते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يتم إرسال أي شيء إلى الخوادم. الإعلانات والتحليلات تستخدم بيانات مجهولة فقط. يمكنك تعطيلها في أي وقت من الإعدادات."
          }
        }
      }
    },

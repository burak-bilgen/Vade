          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चार्ट और सांख्यिकी"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رسوم بيانية وإحصائيات"
          }
        }
      }
    },
    "onboarding.feature.insights.desc": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aylık trendler, döviz dağılımı, kişi bazlı analizler."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Monthly trends, currency breakdowns, per-person analytics."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tendencias mensuales, desglose por moneda, análisis por persona."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "月度趋势、货币分布、个人分析。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मासिक रुझान, मुद्रा विवरण, प्रति-व्यक्ति विश्लेषण।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اتجاهات شهرية، توزيع العملات، تحليلات لكل شخص."
          }
        }
      }
    },

    "people.empty.receivable.title": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alacaklı olduğun kişi yok"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No one owes you money"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nadie te debe dinero"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "没有人欠你钱"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई आपको पैसे नहीं देता"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا أحد يدين لك بالمال"
          }
        }
      }
    },
    "people.empty.receivable.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Birine borç verdiğinde burada görünecek"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When you lend money, it will appear here"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando prestes dinero, aparecerá aquí"
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "当你借钱给别人时，它会出现在这里"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप पैसे उधार देंगे, तो यह यहां दिखाई देगा"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عندما تقرض المال، سيظهر هنا"
          }
        }
      }
    },
    "people.empty.payable.title": {
      "extractionState": "manual",
      "localizations": {

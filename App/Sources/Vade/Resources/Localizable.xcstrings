    "iCloud hesabına giriş yaparsan verilerin diğer cihazlarınla otomatik senkronize olur. Şimdilik yalnızca bu cihazda saklanıyor.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": ""
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in to iCloud to automatically sync your data across devices. For now, data is stored only on this device."

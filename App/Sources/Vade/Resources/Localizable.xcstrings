    "onboarding.welcome.title": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vade"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vade"
          }
        }
      }
    },
    "onboarding.welcome.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Borç-alacak takibin için şık ve güvenli çözüm. Kimseye unutulan bir hesap kalmayacak."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Elegant and secure debt tracking. Never lose track of who owes what."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seguimiento de deudas elegante y seguro. Nunca pierdas de vista quién debe qué."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "优雅安全的债务追踪。不再忘记谁欠了什么。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सुरुचिपूर्ण और सुरक्षित ऋण ट्रैकिंग। कौन क्या बकाया है, कभी न भूलें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتبع ديون أنيق وآمن. لا تفقد أبدًا مسار من يدين بماذا."
          }
        }
      }
    },
    "onboarding.welcome.tagline": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her kuruşun hesabı tutulur, hiçbir şey unutulmaz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every penny accounted for, nothing forgotten."
          }
        }
      }
    },
    "onboarding.features.title": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her şey elinin altında"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything at your fingertips"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo al alcance de tu mano"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一切尽在掌握"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब कुछ आपकी उंगलियों पर"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كل شيء في متناول يدك"
          }
        }
      }
    },
    "onboarding.feature.track": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alacak & Borç Takibi"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track Receivables & Payables"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seguimiento de cuentas por cobrar y pagar"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应收应付追踪"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्राप्य और देय ट्रैकिंग"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتبع المستحقات والمدفوعات"
          }
        }
      }
    },
    "onboarding.feature.track.desc": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kimden alacaklı, kime borçlusun — tek ekranda net gör."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See who owes you and who you owe — all on one screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve quién te debe y a quién le debes, todo en una pantalla."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一目了然谁欠你、你欠谁。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "देखें कौन आपका बकायादार है और आप किसके — एक स्क्रीन पर।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعرف من يدين لك ومن تدين له — كل ذلك في شاشة واحدة."
          }
        }
      }
    },
    "onboarding.feature.insights": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grafikler & İstatistikler"

    "onboarding.feature.reminders.desc": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ödeme günü yaklaşınca sana haber verir, hiçbir şeyi kaçırmazsın."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get notified when payments are due — never miss a thing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibe notificaciones cuando los pagos estén por vencer."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "付款到期时收到通知，不会错过任何事。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "भुगतान की नियत तिथि पर सूचना पाएं — कभी कुछ न चूकें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احصل على إشعارات عند استحقاق المدفوعات — لا تفوّت شيئًا."
          }
        }
      }
    },
    "onboarding.feature.privacy.desc": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verilerin yalnızca cihazında kalır, hiçbir sunucuya gitmez."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your data stays on your device, never sent to any server."
          }
        }
      }
    },
    "onboarding.privacy.title": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verilerin sana ait"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your data stays yours"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus datos son tuyos"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的数据归你所有"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका डेटा आपका ही रहता है"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بياناتك تبقى لك"
          }
        }
      }
    },
    "onboarding.privacy.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiçbir sunucuya gönderilmez. Reklam ve analitik servisleri yalnızca anonim veri kullanır. Dilediğin an Ayarlar'dan kapatabilirsin."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing is sent to servers. Ads and analytics use only anonymous data. You can disable them anytime in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se envía nada a servidores. Los anuncios y análisis solo usan datos anónimos. Puedes desactivarlos en Ajustes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不会发送任何数据到服务器。广告和分析仅使用匿名数据。您可以随时在设置中关闭。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई भी डेटा सर्वर पर नहीं भेजा जाता। विज्ञापन और विश्लेषण केवल गुमनाम डेटा का उपयोग करते हैं। आप सेटिंग्स में कभी भी बंद कर सकते हैं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يتم إرسال أي شيء إلى الخوادم. الإعلانات والتحليلات تستخدم بيانات مجهولة فقط. يمكنك تعطيلها في أي وقت من الإعدادات."
          }
        }
      }
    },
    "onboarding.privacy.icloud": {

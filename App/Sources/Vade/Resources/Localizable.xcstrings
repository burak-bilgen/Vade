    "onboarding.disclaimer.accept": {
      "extractionState": "manual",
      "localizations": {
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu uygulama hukuki belge niteliği taşımaz. Önemli borçlar için noter onaylı yazılı belge alınması önerilir. Veri kaybı veya hesaplama hatalarından sorumluluk kabul edilmez. Okudum, anladım ve kabul ediyorum."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is not a legal document. For important debts, a notarized written agreement is recommended. We accept no liability for data loss or calculation errors. I have read, understood, and accept."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta aplicación no es un documento legal. Para deudas importantes, se recomienda un acuerdo escrito notariado. No aceptamos responsabilidad por pérdida de datos o errores de cálculo. He leído, entendido y acepto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本应用不构成法律文件。对于重要债务，建议使用公证的书面协议。我们不承担数据丢失或计算错误的责任。我已阅读、理解并接受。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह ऐप कानूनी दस्तावेज़ नहीं है। महत्वपूर्ण ऋणों के लिए नोटरीकृत लिखित समझौते की सिफारिश की जाती है। डेटा हानि या गणना त्रुटियों के लिए हम कोई दायित्व स्वीकार नहीं करते। मैंने पढ़ लिया है, समझ लिया है और स्वीकार करता/करती हूं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا التطبيق ليس وثيقة قانونية. بالنسبة للديون المهمة، يوصى باتفاق مكتوب موثق. لا نتحمل أي مسؤولية عن فقدان البيانات أو أخطاء الحساب. لقد قرأت وفهمت وأوافق."
          }
        }
      }
    },
